PROJECT_NAME="AI Social Intelligence Platform"
API_V1_STR="/api/v1"
SECRET_KEY="YOUR_SUPER_SECRET_KEY_HERE"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL Database
# PostgreSQL Database (Commented out because Docker/Postgres might not be running)
# POSTGRES_SERVER=localhost
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=ai_social_db
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# SQLite Fallback for Local Development
DATABASE_URL=sqlite+aiosqlite:///./ai_social_db.db

# n8n Automation
N8N_API_KEY=n8n_secret_token_2026
BASE_URL=http://localhost:8000
ENVIRONMENT=development

# Email Configuration (SMTP)
# For Gmail: Use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=reports@ai-social-intelligence.com
EMAILS_FROM_NAME="AI Social Intelligence Platform"
